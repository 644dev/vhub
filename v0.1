    end
end)

task.spawn(function()
    while true do
        task.wait(0.3)
        if Config.NoRecoil and getgc then
            pcall(function()
                for _, obj in pairs(getgc(true)) do
                    if type(obj) == "table" and (rawget(obj, "Recoil") or rawget(obj, "Spread")) then
                        obj.Recoil, obj.MaxRecoil, obj.Spread, obj.Inaccuracy = 0, 0, 0, 0
                    end
                end
            end)
        end
    end
end)

local function GetAimPart(character)
    if Config.AimPart == "Head" then return character:FindFirstChild("Head")
    elseif Config.AimPart == "Torso" then return character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    end
    return character:FindFirstChild("Head")
end

local DrawingAPI_Available = Drawing and Drawing.new ~= nil
local SkeletonCache, HeadCircleCache = {}, {}
local Bones = {
    {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"},
    {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"}, {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
}

local function ClearESPData(player)
    if SkeletonCache[player] then for _, line in pairs(SkeletonCache[player]) do pcall(function() line:Remove() end) end SkeletonCache[player] = nil end
    if HeadCircleCache[player] then pcall(function() HeadCircleCache[player]:Remove() end) HeadCircleCache[player] = nil end
    if player.Character and player.Character:FindFirstChild("KH_ESP") then player.Character.KH_ESP:Destroy() end
end
Players.PlayerRemoving:Connect(ClearESPData)

local function GetDrawLine(player, index)
    if not SkeletonCache[player] then SkeletonCache[player] = {} end
    if not SkeletonCache[player][index] then
        local line = Drawing.new("Line") line.Thickness = 1.8 line.Transparency = 1 line.Visible = false SkeletonCache[player][index] = line
    end
    return SkeletonCache[player][index]
end

local currentAngle = 0
local CurrentTargetPart = nil 

RunService:BindToRenderStep("KH_CoreEngine", Enum.RenderPriority.Camera.Value + 1, function()
    local CurrentCamera = workspace.CurrentCamera
    if not CurrentCamera then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")

    if Config.Mevlana and hrp then
        currentAngle = (currentAngle + math.rad(Config.MevlanaSpeed * 1.8)) % (math.pi * 2)
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, currentAngle, 0)
    end

    if Config.Aimbot then
        local isAimKeyDown = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        
        if isAimKeyDown then
            local targetInvalid = not CurrentTargetPart or not CurrentTargetPart:IsDescendantOf(workspace)
            if CurrentTargetPart and CurrentTargetPart.Parent and CurrentTargetPart.Parent:FindFirstChild("Humanoid") then
                if CurrentTargetPart.Parent.Humanoid.Health <= 0 then targetInvalid = true end
            end

            if targetInvalid then
                local closest = nil
                local dist = Config.TargetFOV
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local targetPart = GetAimPart(p.Character)
                        if targetPart then
                            local pos, on = CurrentCamera:WorldToViewportPoint(targetPart.Position)
                            if on then
                                local d = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                                if d < dist then dist = d closest = targetPart end
                            end
                        end
                    end
                end
                CurrentTargetPart = closest
            end
            
            if CurrentTargetPart then
                -- Hit Feedback Simülasyonu (Ateş edildiğinde/Hedef varken ses)
                if Config.HitFeedback and Config.HitSound and math.random(1, 20) == 1 then
                    local s = Instance.new("Sound", workspace)
                    s.SoundId = "rbxassetid://86015636" -- Örnek Hitmarker
                    s.Volume = Config.HitVolume s.PlayOnRemove = true s:Destroy()
                end
                CurrentCamera.CFrame = CFrame.lookAt(CurrentCamera.CFrame.Position, CurrentTargetPart.Position)
            end
        else
            CurrentTargetPart = nil
        end
    end

    if FOVCircle then
        pcall(function()
            FOVCircle.Visible = Config.Aimbot
            FOVCircle.Radius = Config.TargetFOV
            FOVCircle.Position = UserInputService:GetMouseLocation()
        end)
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            pcall(function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if Config.ESP then
                        local finalColor = Config.WallColor
                        local head = p.Character:FindFirstChild("Head")
                        if head and CurrentCamera then
                            local rayParams = RaycastParams.new()
                            rayParams.FilterDescendantsInstances = {LocalPlayer.Character, p.Character}
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            if not workspace:Raycast(CurrentCamera.CFrame.Position, head.Position - CurrentCamera.CFrame.Position, rayParams) then
                                finalColor = Config.VisibleColor
                            end
                        end
                        
                        if Config.SkeletonESP then
                            if p.Character:FindFirstChild("KH_ESP") then p.Character.KH_ESP:Destroy() end
                            if DrawingAPI_Available then
                                for i, pair in ipairs(Bones) do
                                    local part1, part2 = p.Character:FindFirstChild(pair[1]), p.Character:FindFirstChild(pair[2])
                                    local line = GetDrawLine(p, i)
                                    if part1 and part2 then
                                        local pos1, on1 = CurrentCamera:WorldToViewportPoint(part1.Position)
                                        local pos2, on2 = CurrentCamera:WorldToViewportPoint(part2.Position)
                                        if on1 or on2 then
                                            line.From, line.To = Vector2.new(pos1.X, pos1.Y), Vector2.new(pos2.X, pos2.Y)
                                            line.Color, line.Visible = finalColor, true
                                        else line.Visible = false end
                                    else line.Visible = false end
                                end
                            end
                        else
                            if SkeletonCache[p] then for _, l in pairs(SkeletonCache[p]) do l.Visible = false end end
                            local high = p.Character:FindFirstChild("KH_ESP")
                            if not high then
                                high = Instance.new("Highlight") high.Name = "KH_ESP"
                                high.FillTransparency = 0.4 high.OutlineTransparency = 0.2 high.Parent = p.Character
                            end
                            high.Adornee, high.FillColor, high.OutlineColor = p.Character, finalColor, finalColor
                        end
                    else
                        ClearESPData(p)
                    end
                end
            end)
        end
    end
end)

