local OrigLighting = {Ambient = Lighting.Ambient, ClockTime = Lighting.ClockTime, Brightness = Lighting.Brightness, FogEnd = Lighting.FogEnd, GlobalShadows = Lighting.GlobalShadows}
RunService.RenderStepped:Connect(function()
