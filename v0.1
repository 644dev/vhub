        Lighting.Ambient = Config.Ambient
        if Config.ClockTime then Lighting.ClockTime = Config.Time end
        if Config.Brightness then Lighting.Brightness = Config.BrightnessValue end
        if Config.Fog then Lighting.FogEnd = Config.FogEnd else Lighting.FogEnd = 100000 end
